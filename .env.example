# ----------------------------------------------------------------------------
# Real-Time Supply-Chain Data Platform - environment
# Copy to `.env` and adjust. All values are local-dev defaults (NOT for prod).
# ----------------------------------------------------------------------------

# --- MinIO / S3 (Iceberg warehouse) ---
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password
AWS_REGION=us-east-1
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
WAREHOUSE_BUCKET=warehouse

# --- Kafka ---
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_BOOTSTRAP_EXTERNAL=localhost:29092

# --- Iceberg REST catalog ---
ICEBERG_REST_URI=http://iceberg-rest:8181

# --- Postgres (shared metadata backend) ---
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

# --- Generator (synthetic data) ---
GEN_EVENTS_PER_SEC=20
GEN_SEED=42

# --- Superset ---
SUPERSET_SECRET_KEY=change-me-in-prod-0123456789abcdef
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Serving API ---
API_KEY=dev-secret-key
API_RATE_LIMIT=120/minute

# --- RAG / LLM ---
OLLAMA_MODEL=llama3.2
QDRANT_URL=http://qdrant:6333

# --- Host port overrides (uncomment to avoid conflicts with other local stacks) ---
# MINIO_API_PORT=9100
# MINIO_CONSOLE_PORT=9111
# KAFKA_EXTERNAL_PORT=39092
# SUPERSET_PORT=8090
# MLFLOW_PORT=5001
# OLLAMA_PORT=11435
