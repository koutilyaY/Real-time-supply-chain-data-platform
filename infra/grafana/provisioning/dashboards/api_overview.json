{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "API requests/sec by endpoint",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(rate(api_requests_total[1m])) by (endpoint)", "legendFormat": "{{endpoint}}"}
      ]
    },
    {
      "type": "timeseries",
      "title": "API p95 latency (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(api_request_seconds_bucket[5m])) by (le, endpoint))", "legendFormat": "{{endpoint}}"}
      ]
    },
    {
      "type": "stat",
      "title": "API error ratio",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "sum(rate(api_requests_total{status=\"error\"}[5m])) / clamp_min(sum(rate(api_requests_total[5m])), 1)"}
      ]
    }
  ],
  "schemaVersion": 39,
  "title": "Supply-Chain API Overview",
  "uid": "scp-api",
  "version": 1
}
