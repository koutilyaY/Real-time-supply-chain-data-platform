FROM python:3.11-slim
WORKDIR /app
# torch + sentence-transformers install from prebuilt wheels; no compiler needed.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY . .
ENV PYTHONUNBUFFERED=1
EXPOSE 8100
CMD ["uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8100"]
